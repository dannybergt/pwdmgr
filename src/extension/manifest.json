{
  "manifest_version": 3,
  "name": "Privora Connect",
  "version": "0.1.0",
  "description": "Zero-knowledge browser extension for pwdmgr/Privora.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Privora"
  }
}

